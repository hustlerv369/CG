# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual envs
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Local secrets (never commit)
.env
.env.local
*.key
*.pem

# Per-run outputs — too noisy for git, regenerable
outputs/*/
!outputs/.gitkeep

# Node (gemini-cli is npm-installed globally; this repo has no node_modules)
node_modules/

# OS launcher artifacts
*.lnk

# Local deploy staging directories (rsynced into the gh-pages branch
# manually; the orphan branch lives separately and we don't want
# its contents shadowed in master)
deploy/

# Cloudflare Tunnel binary + log (downloaded on first launch, not source)
tunnel/cloudflared.exe
tunnel/cloudflared.log
tunnel/*.log

# Browser auth state (secrets)
browser_auth/

# Schedules / notifications / custom_agents — local config
schedules.json
notifications.json
custom_agents.json
